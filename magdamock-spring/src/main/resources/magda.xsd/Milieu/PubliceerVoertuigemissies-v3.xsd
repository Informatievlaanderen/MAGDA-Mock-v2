<xsd:schema xmlns="http://magda.vlaanderen.be/milieu-v3" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:bericht="http://generiek-02_00.vip.vlaanderen.be" xmlns:generiek="http://magda.vlaanderen.be/generiek-v3" targetNamespace="http://magda.vlaanderen.be/milieu-v3" elementFormDefault="unqualified" attributeFormDefault="unqualified">
	<xsd:import namespace="http://magda.vlaanderen.be/generiek-v3" schemaLocation="../Generiek/GeneriekDomein-v3.xsd"/>
	<!--=> ENKELVOUDIGE TYPE DEFINITES-->
	<!--=> SAMENGESTELDE TYPE DEFINITES-->
	<xsd:complexType name="VehicleType">
		<xsd:annotation>
			<xsd:documentation>Container voor de gegevens van het voertuig.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="VehicleId" type="xsd:string">
				<xsd:annotation>
					<xsd:documentation>Gepseudonymiseerde id van het voertuig. Deze waarde moet overeen komen met de VehicleId onder MeasuredVehicle</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CommercialName" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Commerciële benaming van het voertuig.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MakeTypeDescription" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Omschrijving van het type merk van het voertuig</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FirstRegistrationDate" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De datum in CET waarop het voertuig voor het eerst is geregistreerd.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TechnicalPermissibleMaxMass" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De maximaal toegestane massa van het voertuig volgens technische specificaties.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MaxPermMassCombination" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De maximaal toegestane massa van het voertuig inclusief aanhangwagen.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TechControlEntryDatetime" type="xsd:dateTime" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De datum in CET van de laatste technische controle.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FirstKnownUseDate" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De datum in CET waarop het voertuig voor het eerst in gebruik is genomen.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NumberOfStandingPlaces" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Het aantal staanplaatsen in het voertuig.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MassOfTheVehicleInRunningOrder" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De massa van het voertuig in rijklare staat.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ReferenceMass" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De referentiemassa van het voertuig.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MakeName" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Merknaam van het voertuig.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TypeApprovalType" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Het type goedkeuring voor het voertuig.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="IndividualApprovalType" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Individueel goedkeuringstype (geharmoniseerd / niet-geharmoniseerd)</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MaxPermLadenMassNational" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Beoogde maximaal toelaatbare massa in beladen toestand bij registratie / in bedrijf - nationaal</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="VehicleType" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Het voertuigtype dat aanduidt tot welke groep van voertuigen, met gemeenschappelijke kenmerken, het voertuig behoort en waarvoor typegoedkeuring is verleend.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Wvta" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Goedkeuringsnummer. Het goedkeuringsnummer is een uniek nummer volgens een geharmoniseerd nummeringssysteem, op basis waarvan tenminste kan worden vastgesteld welke lidstaat de goedkeuring heeft verleend en aan welke voorschriften het voertuig voldoet.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="PvaBelgium" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Een uniek nummer volgens een nationaal nummeringssysteem, op basis waarvan tenminste kan worden vastgesteld dat voor het voertuig goedkeuring werd verleend en aan welke voorschriften het voertuig voldoet.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Variant" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De voertuigvariant is de variant van een voertuigtype waartoe het voertuig behoort en die alle voertuigen kenmerkt met specifieke gemeenschappelijke bouwkenmerken.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="Version" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De uitvoering van een voertuigvariant waartoe het voertuig behoort en die alle voertuigen kenmerkt met specifieke gemeenschappelijke bouwkenmerken.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="DateCOC" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De datum in CET waarop de COC (certificate of conformity) werd ondertekend.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="TechControlValidityDate" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Geldigheidsdatum in CET technische keuring.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ImportedCertificateRegistrationDate" type="xsd:date" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De datum in CET buitenlandse inschrijving is de datum van de inschrijving waarop het buitenlands inschrijvingsbewijs betrekking heeft. Heeft enkel betrekking op geïmporteerde tweedehandsvoertuigen die eerder waren ingeschreven waren in een ander land.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="OffRoad" type="xsd:boolean" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicator of het een terreinvoertuig betreft. Een terreinvoertuig is een voertuig van categorie M of N met specifieke technische kenmerken waardoor het buiten de normale wegen kan worden gebruikt. Het is een voertuigsubcategorie waarvoor de letter "G" als suffix wordt toegevoegd aan de letter en het cijfer waarmee de voertuigcategorie wordt aangeduid.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ActualMassOfTheVehicle" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De massa van het voertuig in rijklare toestand plus de massa van de optionele uitrusting die op een individueel voertuig is aangebracht.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NumberOfAxles" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Aantal assen van het voertuig.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="HandicapIndicator" type="xsd:boolean" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Aanduiding of het voertuig is aangepast aan mindervaliden</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NrOfSeatingPositions" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Aantal zitplaatsen.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExhaustDirectiveRefCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De Europese goedkeuringsreglementering op basis waarvan tenminste kan worden vastgesteld aan welke emissievoorschriften het voertuig voldoet.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CategoryCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De code van de categorie van het voertuig.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CategoryDescription" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De omschrijving van de categorie van het voertuig</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="KindCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Code die het soort voertuig aangeeft.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="KindDescription" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De omschrijving van het soort voertuig.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StatusCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De code die de status van de inschrijving weergeeft.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="StatusDescription" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De omschrijving van de status van het voertuig.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BodyWorkcode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Het carrosserietype is een Europese indeling en duidt aan welke carrosserievorm het voertuig heeft.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="BodyWorkDescription" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De omschrijving van het carosserietype.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NationalBuildupCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Er bestaan verschillende vormen van carrosserie opbouw van het voertuig. De opbouw is een nationale indeling en duidt aan welke carrosserie opbouw het voertuig heeft.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="NationalBuildupDescription" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De omschrijving van de carosserievorm.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EngineNumber" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De code die door de fabrikant aan een motor wordt toegekend om de adequate identificatie van elke motor mogelijk te maken</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EngineCapacity" type="xsd:float" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De totale cilinderinhoud van de motor in kubieke centimeters.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ElectricEngineIndicator" type="xsd:boolean" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Indicatie electrische motor</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FuelCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Code die het type brandstof van het voertuig aangeeft.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="FuelDescription" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De omschrijving van het type brandstof van het voertuig.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="EuroNormCode" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De emissienorm waaraan het voertuig voldoet.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="MaximumNetPower" type="xsd:float" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Maximaal nettovermogen in kW</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ExhaustEmissionLevelEuro" type="xsd:string" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Het emissieniveau is een Europese code die wordt toegekend aan de emissienorm waaraan het voertuig voldoet.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WeightPowerRatio" type="xsd:float" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De berekende verhouding tussen het nettomaximumvermogen en de rijklare massa van het voertuig bij voertuigen van de categorie L met een verbrandingsmotor.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CombinedFuelConsumption" type="xsd:float" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De totale door het voertuig verbruikte brandstofhoeveelheid tijdens een combinatie van een gestandaardiseerde stadsrit en een rit buiten de stad.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="CombinedCO2" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Gecombineerde CO2</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WLTPcombinedCO2" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Alle aandrijflijnen, CO2-uitstoot van de WLTP gecombineerde testfase</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WeightedCombinedCO2" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Gewogen, gecombineerde CO2</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="WLTPWeightedCombinedCO2" type="xsd:int" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>Alle aandrijflijnen, CO2-uitstoot gewogen gecombineerd met het WLTP-testresultaat</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
			<xsd:element name="ParticulatesMassBenchTest" type="xsd:float" minOccurs="0">
				<xsd:annotation>
					<xsd:documentation>De emissies van deeltjes, gekenmerkt als de massa ervan.</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
