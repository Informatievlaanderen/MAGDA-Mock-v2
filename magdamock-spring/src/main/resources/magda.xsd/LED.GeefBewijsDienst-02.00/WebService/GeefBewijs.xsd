<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema targetNamespace="http://geefbewijs.bewijsraadplegingdienst.led.vlaanderen.be"
           xmlns="http://geefbewijs.bewijsraadplegingdienst.led.vlaanderen.be"
           elementFormDefault="unqualified"
           attributeFormDefault="unqualified"
           version="2.00"
           xmlns:xsd="http://www.w3.org/2001/XMLSchema"
           xmlns:generiek="http://generiek-02_00.vip.vlaanderen.be">
           
	<xsd:import namespace="http://generiek-02_00.vip.vlaanderen.be" schemaLocation="../../Generiek-02.00/Generiek.xsd"/>
	<xsd:element name="GeefBewijs">
		<xsd:complexType>
			<xsd:sequence>
				<xsd:element name="Verzoek" type="VerzoekType"/>
			</xsd:sequence>
		</xsd:complexType>
	</xsd:element>
	<xsd:complexType name="VerzoekType">
		<xsd:sequence>
			<xsd:element name="Context" type="generiek:ContextType"/>
			<xsd:element name="Vragen" type="VragenType"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="VragenType">
		<xsd:sequence>
			<xsd:element name="Vraag" type="VraagType" minOccurs="1" maxOccurs="1"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="VraagType">
		<xsd:sequence>
			<xsd:element name="Referte" type="generiek:ReferteType"/>
			<xsd:element name="Inhoud" type="VraagInhoudType"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="VraagInhoudType">
		<xsd:sequence>
			<xsd:element name="INSZ" type="generiek:INSZType">
				<xsd:annotation>
					<xsd:documentation>
						Het INSZ van de persoon waarvoor de bewijzen worden opgevraagd.
						Dit MOET het actuele INSZ zijn.
						Indien dit niet het geval is dan zal de vraag niet succesvol zijn. 						
						Verplicht.
						
						Een succesvolle vraag leidt altijd tot een repliek met daarin een
						Inhoud en een AntwoordInhoud.
						Een niet succesvolle vraag leidt altijd tot een repliek met daarin
						een Uitzonderingen element met uitzonderingen.															
					</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
</xsd:schema>
