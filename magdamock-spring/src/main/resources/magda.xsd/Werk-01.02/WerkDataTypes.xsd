    <xs:complexType name="BronCodeType">
        <xs:annotation>
            <xs:documentation>is een extension van simpel Type 'BronCodeType' + beschrijving</xs:documentation>
        </xs:annotation>
        <xs:simpleContent>
            <xs:extension base="BronEnumType">
                <xs:attribute name="Beschrijving" type="xs:string"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>

    <xs:complexType name="ContractType">
        <xs:sequence>
            <xs:element name="Werkgever" type="WerkgeverAntwoordType" minOccurs="0"/>
            <xs:element name="Werknemer" type="WerknemerAntwoordType"/>
            <xs:element name="Aangifte" type="AangifteType"/>
            <xs:element name="Gebruiker" type="GebruikerType" minOccurs="0"/>
            <xs:element name="PlaatsTewerkstelling" type="PlaatsTewerkstellingType" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="GeslachtCodeType">
        <xs:annotation>
            <xs:documentation>is een extension van simpel Type 'GeslachtEnumType' + beschrijving</xs:documentation>
        </xs:annotation>
        <xs:simpleContent>
            <xs:extension base="GeslachtEnumType">
                <xs:attribute name="Beschrijving" type="xs:string"/>
                <xs:attribute name="DatumModificatie" type="generiek:DatumType">
                    <xs:annotation>
                        <xs:documentation>Geeft aan wanneer de laatste wijziging aan de naam van deze persoon is gebeurd, enkel gebruik bij Antwoord.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
    
    <xs:complexType name="NationaliteitsType">
        <xs:complexContent>
            <xs:extension base="generiek:LandType">
                <xs:attribute name="DatumModificatie" type="generiek:DatumType">
                    <xs:annotation>
                        <xs:documentation>Dag waarop de nationaliteit werd verworven. Indien niet ingevuld is dit ofwel niet gekend ofwel de geboortedatum. Enkel gebruik bij Antwoord.</xs:documentation>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    
</xs:schema>
