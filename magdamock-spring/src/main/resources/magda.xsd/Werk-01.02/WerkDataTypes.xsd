<xs:schema targetNamespace="http://werk-01_02.vip.vlaanderen.be"
		   xmlns="http://werk-01_02.vip.vlaanderen.be" 
		   xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:generiek="http://generiek-01_02.vip.vlaanderen.be"
           elementFormDefault="unqualified"
           attributeFormDefault="unqualified" 
           version="1.02">
           
    <xs:import namespace="http://generiek-01_02.vip.vlaanderen.be" schemaLocation="../Generiek-01.02/Generiek.xsd"/>
    <xs:include schemaLocation="WerkDataKern.xsd"/>
    <xs:include schemaLocation="WerkDataCodes.xsd"/>
    
    <xs:complexType name="WerkgeverVraagType">
        <xs:annotation>
            <xs:documentation>Werkgever</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Bron" type="BronInputEnumType" minOccurs="0"/>
            <xs:element name="RSZNummer" type="RSZNummerInputType" minOccurs="0"/>
            <xs:element name="OndernemingsNummer" type="OndernemingsNummerInputType" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="WerknemerVraagType">
        <xs:sequence>
            <xs:element name="INSZ" type="generiek:INSZType"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="VolgendType">
        <xs:sequence>
            <xs:element name="LijnNummer" type="VolgendLijnNrType"/>
            <xs:element name="Ticket" type="VolgendTicketType"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="VolgendAntwoordType">
        <xs:sequence>
            <xs:element name="LijnNummer" type="VolgendLijnNrType" minOccurs="0"/>
            <xs:element name="Ticket" type="VolgendTicketType" minOccurs="0"/>
            <xs:element name="TotaalAantalLijnen" type="VolgendTotaalAantalLijnenType" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="WerkgeverAntwoordType">
        <xs:annotation>
            <xs:documentation>Werkgever</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="RSZNummer" type="RSZNummerType" minOccurs="0"/>
            <xs:element name="OndernemingsNummer" type="OndernemingsNummerType" minOccurs="0"/>
            <xs:element name="Bron" type="BronCodeType" minOccurs="0"/>
            <xs:element name="DeelEntiteit" type="DeelEntiteitType" minOccurs="0"/>
            <xs:element name="Kinderbijslagfonds" type="KinderbijslagfondsType" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="KinderbijslagfondsType">
        <xs:sequence>
            <xs:element name="Nummer" type="KBFondsNummerType"/>
            <xs:element name="Dossier" type="KBFondsDossierType" minOccurs="0"/>
            <xs:element name="Bureau" type="KBFondsBureauType" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>
    
    <xs:complexType name="WerknemerAntwoordType">
        <xs:sequence>
            <xs:element name="INSZ" type="generiek:INSZType"/>
            <xs:element name="IdentificatiePersoon" type="generiek:VlagCodeType"/>
            <xs:element name="Naam" type="generiek:NaamLangType" minOccurs="0"/>
            <xs:element name="Voornaam" type="generiek:NaamKortType" minOccurs="0"/>
            <xs:element name="Geboortedatum" type="generiek:DatumType" minOccurs="0"/>
            <xs:element name="Geslacht" type="GeslachtCodeType" minOccurs="0"/>
            <xs:element name="Nationaliteit" type="NationaliteitsType" minOccurs="0"/>            
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="AangifteType">
        <xs:sequence>
            <xs:element name="DimonaNummer" type="DimonaNummerType"/>
            <xs:element name="Periode" type="generiek:PeriodeType" minOccurs="0"/>
            <xs:element name="ParitairComite" type="ParitairComiteType" minOccurs="0"/>
            <xs:element name="AardWerknemer" type="AardWerknemerType" minOccurs="0"/>
            <xs:element name="DimonaActie" type="DimonaActieType" minOccurs="0"/>
            <xs:element name="ValidatieStatus" type="generiek:VlagCodeType" minOccurs="0"/>
            <xs:element name="Tijdsregistratie" type="TijdsRegistratieType" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="TijdsRegistratieType">
        <xs:sequence>
            <xs:element name="BeginTijd" type="generiek:TijdType" minOccurs="0"/>
            <xs:element name="EindTijd" type="generiek:TijdType" minOccurs="0"/>
            <xs:element name="DuurCode" type="DuurCodeType" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="GebruikerType">
        <xs:sequence>
            <xs:element name="Benaming" type="BenamingType" minOccurs="0"/>
            <xs:element name="RSZNummer" type="RSZNummerType" minOccurs="0"/>
            <xs:element name="OndernemingsNummer" type="OndernemingsNummerType" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="PlaatsTewerkstellingType">
        <xs:sequence>
            <xs:element name="Adres" type="AdresType" minOccurs="0"/>
            <xs:element name="Benaming" type="generiek:NaamLangType" minOccurs="0"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="AdresType">
        <xs:sequence>
            <xs:element name="Straat" type="generiek:StraatNaamType"/>
            <xs:element name="Busnummer" type="BusNummerType" minOccurs="0"/>
            <xs:element name="Gemeente" type="GemeenteInternationaalType"/>
            <xs:element name="Land" type="generiek:LandType"/>
        </xs:sequence>
    </xs:complexType>

    <xs:complexType name="GemeenteInternationaalType">
        <xs:annotation>
            <xs:documentation>GemeenteInternationaalType</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="NISCode" type="generiek:GemeenteNISCodeType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Code van de locatie, altijd NIS-codes. Het formaat van gemeentecodes heeft 5 cijfers.</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="PostCode" type="PostCodeInternationaalType">
                <xs:annotation>
                    <xs:documentation>Postcode van de gemeente</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Naam" type="generiek:NaamLangType">
                <xs:annotation>
                    <xs:documentation>Naam van de gemeente</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>

	<!-- 
	<xs:complexType name="LandType">
		<xs:annotation>
			<xs:documentation>LandType</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="ISOCode" type="generiek:LandISOCodeType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Land of nationaliteitscode in ISO formaat, er moet een omzetting gebeuren van NIS code naar iso code.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="NISCode" type="generiek:LandNISCodeType">
				<xs:annotation>
					<xs:documentation>Land of nationaliteitscode in NIS formaat. Het formaat van landcodes heeft 3 cijfers.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Naam" type="xs:string" minOccurs="0">
