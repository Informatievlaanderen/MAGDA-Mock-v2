		   version="1.02.201107141455">
	<xs:import namespace="http://generiek-01_02.vip.vlaanderen.be" schemaLocation="../Generiek-01.02/Generiek.xsd"/>
	<xs:include schemaLocation="LerendeDataCodes.xsd"/>
	<xs:include schemaLocation="LerendeDataKern.xsd"/>
