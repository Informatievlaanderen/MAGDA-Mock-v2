		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="OnderwerpInhoudType">
		<xs:sequence>
			<xs:element name="Metadata" type="generiek:MetadataType" minOccurs="0"/>
			<xs:element name="MutatieSocialeStatuten" type="soczek:MutatieSocialeStatutenType"/>
		</xs:sequence>
	</xs:complexType>
