		   elementFormDefault="unqualified"
		   attributeFormDefault="unqualified">
	<xs:import namespace="http://generiek-02_00.vip.vlaanderen.be" schemaLocation="../../Generiek-02.00/Generiek.xsd"/>
	<xs:import namespace="http://soczek-02_00.vip.vlaanderen.be" schemaLocation="../../SocZek-02.00/SocZek.xsd"/>
	<xs:element name="PubliceerMutatieSocialeStatuten">
		<xs:complexType>
			<xs:sequence>
				<xs:element name="Publicatie" type="PublicatieType"/>
			</xs:sequence>
		</xs:complexType>
	</xs:element>
	<xs:complexType name="PublicatieType">
		<xs:sequence>
			<xs:element name="Context" type="generiek:ContextType"/>
			<xs:element name="Onderwerpen" type="OnderwerpenType" minOccurs="0"/>
			<xs:element name="Uitzonderingen" type="generiek:UitzonderingenType" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="OnderwerpenType">
		<xs:sequence>
			<xs:element name="Onderwerp" type="OnderwerpType" maxOccurs="1000000"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="OnderwerpType">
		<xs:sequence>
			<xs:element name="Referte" type="generiek:ReferteType"/>
