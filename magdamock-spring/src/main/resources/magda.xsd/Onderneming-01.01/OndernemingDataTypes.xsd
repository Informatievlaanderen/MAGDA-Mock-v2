			<xs:extension base="AdresType">
				<xs:sequence>
					<xs:element name="Aanvulling" type="AdresAanvullingsType" minOccurs="0">
						<xs:annotation>
							<xs:documentation>Aanvulling</xs:documentation>
						</xs:annotation>
					</xs:element>
				</xs:sequence>
			</xs:extension>
		</xs:complexContent>
