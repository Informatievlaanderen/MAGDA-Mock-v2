	<xs:complexType name="OndernemingenType">
		<xs:annotation>
			<xs:documentation>OndernemingenType</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Onderneming" type="OndernemingType" maxOccurs="unbounded">
				<xs:annotation>
					<xs:documentation>Onderneming</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="OndernemingType">
		<xs:annotation>
			<xs:documentation>De generische elementen van de onderneming zijn opgedeeld in 5 blokken : kern-, naam-, levenscyclus-, adres- en contactgegevens. </xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="OndernemingsNummer" type="OndernemingsNummerType">
				<xs:annotation>
					<xs:documentation>Dit identificatienummer is een uniek nummer dat toegekend wordt aan een onderneming of vestigingseenheid. </xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="RSZNummer" type="RSZNummerType" minOccurs="0" maxOccurs="20">
				<xs:annotation>
					<xs:documentation>Het RSZ nummer van de onderneming, heeft unbounded occurency.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AuthentiekeBronCode" type="generiek:AuthentiekeBronCodeType">
				<xs:annotation>
					<xs:documentation>AuthentiekeBronCode</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="StatusKBOCode" type="StatusKBOCodeType">
				<xs:annotation>
					<xs:documentation>Code die de status van de onderneming aanduidt.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="OndernemingOfVestigingCode" type="OndernemingOfVestigingCodeType">
				<xs:annotation>
					<xs:documentation>Deze code geeft de indicatie of het gaat over een onderneming of een vestigingseenheid.  </xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="SoortOndernemingCode" type="SoortOndernemingCodeType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Code die natuurlijk persoon of rechtspersoon aanduidt.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="MZOndNummer" type="OndernemingsNummerType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>In geval van een vestigingseenheid bevat dit veld het ondernemingsnummer van de maatschappelijke zetel</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="MaatschappelijkeNaam" type="NaamExtraLangTaalType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>De maatschappelijke benaming van een onderneming of vestigingseenheid, en dit in de opgegeven taal. Voor onderneming van natuurlijke personen : maatschappelijke naam = naam + eerste voornaam natuurlijke persoon (verplicht).  Voor rechtspersonen : maatschappelijke naam (verplicht).   Voor vestigingseenheid : geen maatschappelijke naam.  NaamLangTaalType is een extension op NaamExtraLangType.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="CommercieleNaam" type="NaamExtraLangTaalType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>De commerciele benaming van een onderneming of vestigingseenheid en dit in de opgegeven taal. Voor onderneming van natuurlijke personen is er geen specifieke regel.  Voor rechtspersonen is dit de handelsnaam (optioneel).  Voor vestigingseenheid is dit de handelsnaam (optioneel).  NaamLangTaalType is een extension op NaamExtraLangType.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="AfgekorteNaam" type="NaamExtraLangTaalType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>De afgekorte benaming van een onderneming of vestigingseenheid en dit in de opgegeven taal.  Voor onderneming van natuurlijke personen is er geen afkorting.  Voor rechtspersonen is de afkorting optioneel. Voor vestigingseenheid is er geen afkorting. NaamLangTaalType is een extension op NaamExtraLangType.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Adres" type="OndernemingsAdresType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>VestigingsAdres</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Contact" type="ContactType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Contact</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DatumInschrijving" type="generiek:DatumType">
				<xs:annotation>
					<xs:documentation>Datum van inschrijving van de onderneming in de kruispuntbank ondernemingen. Dit gebeurt bij aanvraag tot oprichting van de onderneming.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DatumStart" type="generiek:DatumType">
				<xs:annotation>
					<xs:documentation>De datum waarop de onderneming is opgericht. Voor rechtspersonen die opgericht worden met een authentieke akte, is dit de datum waarop de akte gedagtekend wordt.  Voor rechtspersonen zonder authentieke akte (onderhands, bepaald bij wet of KB's, ...) is dit de datum waarop de rechtspersonen erkend worden ten opzichte van derden. Voor ondernemingen van natuurlijke personen is dit de datum waarop de natuurlijke persoon met de onderneming zal starten.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="RechtsToestandCode" type="RechtsToestandCodeType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>De code die de rechtstoestand van de onderneming weerspiegelt.  Bvb : in oprichting, opgericht, gerechtelijk akkoord aangevraagd, ...</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="RechtsVormCode" type="RechtsVormCodeType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Geeft de code van de rechtsvorm aan die van toepassing is op de rechtspersoon of organisatie zonder rechtspersoonlijkheid.</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Stopzetting" type="StopzettingType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Stopzetting</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DatumAfsluiting" type="generiek:DatumType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>DatumAfsluiting</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
		<xs:attribute name="DatumModificatie" type="generiek:DatumType" use="required">
			<xs:annotation>
				<xs:documentation>De datum waarop dit record het laatst gewijzigd werd in KBO kopie.</xs:documentation>
			</xs:annotation>
		</xs:attribute>
	</xs:complexType>
	<xs:complexType name="VestigingenType">
		<xs:annotation>
			<xs:documentation>VestigingenType</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Vestiging" type="VestigingType" maxOccurs="unbounded">
				<xs:annotation>
