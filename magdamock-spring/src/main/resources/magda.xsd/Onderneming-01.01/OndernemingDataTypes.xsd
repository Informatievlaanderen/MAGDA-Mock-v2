	<xs:complexType name="StopzettingType">
		<xs:annotation>
			<xs:documentation>StopzettingType</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="RedenStopzettingCode" type="RedenStopzettingCodeType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Als een onderneming wordt stopgezet, geeft deze code de reden van stopzetting aan</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="DatumStopzetting" type="generiek:DatumType" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Datum waarop de onderneming is stopgezet. Een onderneming die stopgezet is, kan nog opnieuw geactiveerd worden indien nodig. Zolang de onderneming niet is gestopt, blijft de datum leeg.</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
