                </xs:annotation>
            </xs:element>
            <xs:element name="TekstAdres" type="TekstAdresType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>TekstAdres</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
