<xs:schema targetNamespace="http://persoon-01_02.vip.vlaanderen.be"
		   xmlns="http://persoon-01_02.vip.vlaanderen.be"
           xmlns:xs="http://www.w3.org/2001/XMLSchema"
           xmlns:generiek="http://generiek-01_02.vip.vlaanderen.be"
           elementFormDefault="unqualified" 
           attributeFormDefault="unqualified" 
           version="1.02">
           
    <xs:import namespace="http://generiek-01_02.vip.vlaanderen.be" schemaLocation="../Generiek-01.02/Generiek.xsd"/>
    <xs:include schemaLocation="PersoonDataCodes.xsd"/>
    <xs:include schemaLocation="PersoonDataKern.xsd"/>
      	
    <xs:complexType name="GebeurtenisType">
        <xs:annotation>
            <xs:documentation>GebeurtenisType</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Datum" type="generiek:DatumType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Datum van gebeurtenis</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Gemeente" type="generiek:GemeenteType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Gemeente</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Land" type="generiek:LandType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Land moet niet noodzakelijk ingevuld zijn. Indien niet ingevuld, kan dit evenuteel
                        uit de gemeente afgeleid worden. Indien niet, is het land België.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="GebeurtenisMetDatumType">
        <xs:complexContent>
            <xs:extension base="GebeurtenisType">
                <xs:attribute name="DatumModificatie" type="generiek:DatumType">
                    <xs:annotation>
                        <xs:documentation>Geeft aan wanneer de laatste wijziging aan de naam van deze persoon is
                            gebeurd, enkel gebruik bij Antwoord.
                        </xs:documentation>
                    </xs:annotation>
                </xs:attribute>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="GebeurtenisCriteriaType">
        <xs:annotation>
            <xs:documentation>Algemeen segment dat kan gebruikt worden om gebeurtenis aan te geven op bepaalde plaats en
                op bepaalde datum
            </xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Periode" type="generiek:PeriodeType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Datum van gebeurtenis</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="StraatCriteriaType">
        <xs:annotation>
            <xs:documentation>StraatCriteriaType</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="NISCode" type="generiek:StraatNISCodeType">
                <xs:annotation>
                    <xs:documentation>NIS Code. Voor straat kan deze bestaan uit 3 of 4 cijfers.</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="GemeenteCriteriaType">
        <xs:annotation>
            <xs:documentation>GemeenteCriteriaType</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="PostCode" type="generiek:PostCodeType">
                <xs:annotation>
                    <xs:documentation>Postcode van de gemeente</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
    <xs:complexType name="AdresSoortCodeType">
        <xs:annotation>
            <xs:documentation>is een extension van simpel Type 'string' + beschrijving</xs:documentation>
        </xs:annotation>
        <xs:simpleContent>
            <xs:extension base="xs:string">
                <xs:attribute name="Beschrijving" type="xs:string"/>
