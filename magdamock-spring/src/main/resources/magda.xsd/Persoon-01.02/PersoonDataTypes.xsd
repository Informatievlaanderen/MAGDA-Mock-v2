    <xs:complexType name="PersoonNaamType">
        <xs:annotation>
            <xs:documentation>PersoonNaamType</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="Achternaam" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Familienaam</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Voornaam" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Eerste voornaam</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="TweedeVoornaam" type="xs:string" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Tweede voornaam</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="VoornaamVolledigVlag" type="generiek:VlagCodeType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Controlevlag of volledige voornamen zijn meegedeeld. Heeft waarde '0' bij 1
                        voornaam of 2 waarvan één onvolledig is. Heeft waarde '1' bij 2 volledige voornamen, beide
                        voornamen zijn gescheiden door een blanco.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
        <xs:attribute name="DatumModificatie" type="generiek:DatumType">
            <xs:annotation>
                <xs:documentation>Geeft aan wanneer de laatste wijziging aan de naam van deze persoon is gebeurd, enkel
                    gebruik bij Antwoord.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
