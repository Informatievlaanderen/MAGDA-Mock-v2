            <xs:annotation>
                <xs:documentation>Geeft aan wanneer de laatste wijziging aan de naam van deze persoon is gebeurd, enkel
                    gebruik bij Antwoord.
                </xs:documentation>
            </xs:annotation>
        </xs:attribute>
        <xs:attribute name="AuthentiekeBron" type="generiek:AuthentiekeBronEnumType">
            <xs:annotation>
                <xs:documentation>AuthentiekeBron</xs:documentation>
            </xs:annotation>
        </xs:attribute>
    </xs:complexType>
    <xs:complexType name="RelatieCodeType">
        <xs:annotation>
            <xs:documentation>is een extension van simpel Type relatiecode + beschrijving</xs:documentation>
        </xs:annotation>
        <xs:simpleContent>
            <xs:extension base="xs:string">
                <xs:attribute name="Beschrijving" type="xs:string"/>
            </xs:extension>
        </xs:simpleContent>
    </xs:complexType>
    <xs:complexType name="GeslachtCodeType">
