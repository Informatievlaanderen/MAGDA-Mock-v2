            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
    <xs:complexType name="PersoonBeknoptType">
        <xs:annotation>
            <xs:documentation>PersoonBeknoptType</xs:documentation>
        </xs:annotation>
        <xs:sequence>
            <xs:element name="INSZ" type="generiek:INSZType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Het INSZ (Identificatienummer Sociale Zekerheid), RR of Bis nummer. De inhoud van
                        dit veld moet precies 11 tekens lang zijn; voorloopnullen mogen niet worden weggelaten.
                    </xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Naam" type="PersoonNaamType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Naam</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="Geslacht" type="GeslachtCodeType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Geslacht</xs:documentation>
                </xs:annotation>
            </xs:element>
            <xs:element name="GeboorteDatum" type="generiek:DatumType" minOccurs="0">
                <xs:annotation>
                    <xs:documentation>Naam</xs:documentation>
                </xs:annotation>
            </xs:element>
        </xs:sequence>
    </xs:complexType>
