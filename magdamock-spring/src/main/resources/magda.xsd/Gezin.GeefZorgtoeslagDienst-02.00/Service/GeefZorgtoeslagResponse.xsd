				<xsd:annotation>
					<xsd:documentation>Fouten die voorkomen na de verwerking van Vraag of Antwoord bv: warnings rond ontbrekende data en fouten gelinked aan 1 antwoord</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="AntwoordInhoudType">
		<xsd:sequence>
			<xsd:element name="Zorgtoeslag" type="gezin:ZorgtoeslagType">
				<xsd:annotation>
					<xsd:documentation>Zorgtoeslag informatie die betrekking heeft op de op vraag criteria</xsd:documentation>
				</xsd:annotation>
			</xsd:element>
		</xsd:sequence>
