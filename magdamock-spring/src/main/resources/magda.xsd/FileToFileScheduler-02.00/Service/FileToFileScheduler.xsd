	<xsd:complexType name="A1CreatieInhoudType">
		<xsd:choice>
			<xsd:sequence>
				<xsd:element name="Proces" type="xsd:string" minOccurs="0"/>
				<xsd:element name="Versie" type="xsd:string" minOccurs="0"/>
			</xsd:sequence>
			<xsd:sequence>
				<xsd:choice>
					<xsd:element name="A800" type="A800Type"/>
				</xsd:choice>
			</xsd:sequence>
		</xsd:choice>
	</xsd:complexType>
	<xsd:complexType name="A1Type">
		<xsd:sequence>
			<xsd:element name="Voorlegging" type="A1VoorleggingType" minOccurs="0" maxOccurs="1"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="A1CreatieType">
		<xsd:complexContent>
			<xsd:extension base="A1Type">
				<xsd:sequence>
					<xsd:element name="Inhoud" type="A1CreatieInhoudType" minOccurs="0" maxOccurs="1"/>
				</xsd:sequence>
			</xsd:extension>
		</xsd:complexContent>
	</xsd:complexType>
	<xsd:complexType name="A1HeaderInhoudType">
		<xsd:sequence>
			<xsd:element name="MailboxNumber" type="HeaderLocationType"/>
			<xsd:element name="NumberOfRecords" type="HeaderLocationType"/>
			<xsd:element name="FileSize" type="HeaderLocationType"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="A1HeaderType">
		<xsd:complexContent>
			<xsd:extension base="A1Type">
				<xsd:sequence>
					<xsd:element name="HeaderInhoud" type="A1HeaderInhoudType" minOccurs="0" maxOccurs="1"/>
				</xsd:sequence>
			</xsd:extension>
		</xsd:complexContent>
	</xsd:complexType>
	<xsd:complexType name="PubliceerV3ParametersType">
		<xsd:sequence>
			<xsd:element name="Context" type="generiekV3:ContextType"/>
			<xsd:element name="BestandPrefix" type="xsd:string"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="HeaderLocationType">
		<xsd:simpleContent>
			<xsd:extension base="xsd:string">
				<xsd:attribute name="Start" type="xsd:int"/>
				<xsd:attribute name="Einde" type="xsd:int"/>
				<xsd:attribute name="xpath" type="xsd:boolean"/>
				<xsd:attribute name="KorteWaardeAanvullen" type="KorteWaardeAanvullenType" default="BLOKKEER"/>
				<xsd:attribute name="bron" type="ConfiguratieWaardeBronType" default="DEFAULT"/>
			</xsd:extension>
		</xsd:simpleContent>
	</xsd:complexType>
	<xsd:simpleType name="KorteWaardeAanvullenType">
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="BLOKKEER"/>
			<xsd:enumeration value="BLANKOLINKS"/>
			<xsd:enumeration value="BLANKORECHTS"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="ConfiguratieWaardeBronType">
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="DEFAULT"/>
			<xsd:enumeration value="CUSTOM"/>
			<!--<xsd:enumeration value="CONTEXT"/>
            <xsd:enumeration value="INHOUD"/>-->
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="FileRenamingPatternEnumType">
		<xsd:annotation>
			<xsd:documentation>
				Deze enum wordt gebruikt in de optionele annotatie om aan te duiden werke methode moet gebruikt worden
				bij het verwerken van de FileRenamingStrategyPattern
			</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="TIMESTAMP"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:complexType name="PubliceerInwonersPerAdresParametersType">
		<xsd:sequence>
			<xsd:element name="OutputFilePrefix" type="xsd:string"/>
			<xsd:element name="UnzipFolder" type="xsd:string"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="XsltParametersType">
		<xsd:sequence>
			<xsd:element name="TemplateFileName" type="xsd:string"/>
			<xsd:element name="TemplateParameters" type="TemplateParametersType" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="TemplateParametersType">
		<xsd:sequence>
			<xsd:element name="Parameter" type="ParameterType" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="ParameterType">
		<xsd:attribute name="key" type="xsd:string"/>
		<xsd:attribute name="value" type="xsd:string"/>
	</xsd:complexType>
</xsd:schema>
