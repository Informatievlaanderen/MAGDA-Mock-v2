					<xsd:sequence>
						<xsd:element name="Formulier" type="HeaderLocationType"/>
						<xsd:element name="Variante" type="HeaderLocationType"/>
						<xsd:element name="GedeelteBericht" type="HeaderLocationType"/>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Antwoordgedeelte">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="IdentificatieToepassing" type="HeaderLocationType"/>
						<xsd:element name="ReferentieBeantwoorder" type="HeaderLocationType"/>
						<xsd:element name="DatumVraag" type="HeaderLocationType"/>
						<xsd:element name="TermijnAntwoord" type="HeaderLocationType"/>
						<xsd:element name="TimeOutActie" type="HeaderLocationType"/>
						<xsd:element name="SlagingStroom" type="HeaderLocationType"/>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Repertoriumgedeelte">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="Hoedanigheidscode" type="HeaderLocationType"/>
						<xsd:element name="Fase" type="HeaderLocationType"/>
						<xsd:element name="RepertoriumBegin" type="HeaderLocationType"/>
						<xsd:element name="RepertoriumEinde" type="HeaderLocationType"/>
						<xsd:element name="BerichtBegin" type="HeaderLocationType"/>
						<xsd:element name="BerichtEinde" type="HeaderLocationType"/>
						<xsd:element name="LeverancierSector" type="HeaderLocationType"/>
						<xsd:element name="TypeInstelling" type="HeaderLocationType"/>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
			<xsd:element name="Netwerkgedeelte">
				<xsd:complexType>
					<xsd:sequence>
						<xsd:element name="Netwerk" type="HeaderLocationType"/>
						<xsd:element name="Versie" type="HeaderLocationType"/>
						<xsd:element name="Sector" type="HeaderLocationType"/>
						<xsd:element name="TypeInstelling" type="HeaderLocationType"/>
						<xsd:element name="InterneReferentieSector" type="HeaderLocationType"/>
						<xsd:element name="GebruikersID" type="HeaderLocationType"/>
						<xsd:element name="TypeAanvraag" type="HeaderLocationType"/>
						<xsd:element name="INSZ" type="HeaderLocationType"/>
					</xsd:sequence>
				</xsd:complexType>
			</xsd:element>
