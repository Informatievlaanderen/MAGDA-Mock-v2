			<xsd:enumeration value="A1TRANSFORMER"/>
			<xsd:enumeration value="RRANON"/>
			<xsd:enumeration value="CREATELOTDEMESSAGES"/>
			<xsd:enumeration value="VALIDATELOTDEMESSAGES"/>
			<xsd:enumeration value="PMP0200"/>
			<xsd:enumeration value="PMP0102"/>
			<xsd:enumeration value="PSC0200"/>
			<xsd:enumeration value="A820"/>
			<xsd:enumeration value="A820MUT"/>
			<xsd:enumeration value="A014"/>
			<xsd:enumeration value="MALBO2CBNOTS"/>
			<xsd:enumeration value="CBNOTS2RALBO"/>
			<xsd:enumeration value="FLITS2TOEGANGCONTROLE"/>
			<xsd:enumeration value="TOEGANGCONTROLE2CSV"/>
			<xsd:enumeration value="LEZGEGEVENS2XML"/>
			<xsd:enumeration value="LEZGEGEVENS2CSV"/>
			<xsd:enumeration value="TOEGANGCONTROLE2CSVPATCH"/>
			<xsd:enumeration value="DIVANON"/>
			<xsd:enumeration value="RESULTFLASHENRICH"/>
			<xsd:enumeration value="SOCIAALSTATUUTLIJSTREQUEST"/>
			<xsd:enumeration value="SOCIAALSTATUUTLIJSTRESPONSE"/>
			<xsd:enumeration value="REGISTREERAANVRAAGZORGTOESLAG"/>
			<xsd:enumeration value="PUBLICEERSOCIALESCHULD"/>
			<xsd:enumeration value="LOTDEMESSAGESVALIDATORSPLITTER"/>
			<xsd:enumeration value="VLOKCSV2PUBMUTNOT0201"/>
			<xsd:enumeration value="PUBLICEERMUTATIEZORGTOESLAG"/>
			<xsd:enumeration value="REGISTREERMUTATIEZORGTOESLAG"/>
			<xsd:enumeration value="PUBLICEERKINDTENLASTE"/>
			<xsd:enumeration value="MUTATIESOCIALESTATUTEN"/>
			<xsd:enumeration value="FEEDBACKSOCIALESTATUTEN"/>
			<xsd:enumeration value="WERKNEMERBIJDRAGEVERMINDERING"/>
			<xsd:enumeration value="PUBLICEERINWONERSPERADRES"/>
			<xsd:enumeration value="XSLT"/>
			<xsd:enumeration value="RENAME2LDMDATAFILE"/>
			<xsd:enumeration value="PUBLICEERATTESTKINDTENLASTE30"/>
			<xsd:enumeration value="PUBLICEERVLIMPERSDOWNLOAD"/>
            <xsd:enumeration value="NOTIFYPERSONDATA"/>
            <xsd:enumeration value="NOTIFYPERSONSSIN"/>
        </xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="TypeOrganisatieEnumType">
		<xsd:annotation>
			<xsd:documentation>S (op basis van sector/instelling) | E (ondernemingsnummer)</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="S"/>
			<xsd:enumeration value="E"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OmgevingEnumType">
		<xsd:annotation>
			<xsd:documentation>t (test)| a (acceptatie) | p (productie)</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="T"/>
			<xsd:enumeration value="A"/>
			<xsd:enumeration value="P"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="SyntaxEnumType">
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="XML"/>
			<xsd:enumeration value="INHOUSE"/>
			<xsd:enumeration value="FLAT"/>
			<xsd:enumeration value="A1"/>
			<xsd:enumeration value="CSV"/>
			<xsd:enumeration value="UNKNOWN"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="IntegriteitsMethodeEnumType">
		<xsd:annotation>
			<xsd:documentation>MD5| DSIG</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="MD5"/>
			<xsd:enumeration value="DSIG"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="BooleanType">
		<xsd:restriction base="xsd:string">
			<xsd:length value="1"/>
			<xsd:pattern value="(0|1)"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="AfnemerCodeType">
		<xsd:restriction base="xsd:string">
