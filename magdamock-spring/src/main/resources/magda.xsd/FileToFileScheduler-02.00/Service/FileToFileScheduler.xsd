	<xsd:complexType name="GegevensStroomFormaatTransformatorStroomAfnemersType">
		<xsd:annotation>
			<xsd:documentation>Gebruikt voor output, vb. elke afnemer kan een eigen encoding wensen.</xsd:documentation>
		</xsd:annotation>
		<xsd:sequence>
			<xsd:element name="GegevensStroomFormaatTransformatorStroomAfnemer" type="GegevensStroomFormaatTransformatorStroomAfnemerType" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="GegevensStroomFormaatTransformatorStroomAfnemerType">
		<xsd:sequence>
			<xsd:element name="Naam" type="xsd:string"/>
			<xsd:choice>
				<xsd:element name="PersoonAfnemerIdentificatie" type="PersoonAfnemerIdentificatieType"/>
				<xsd:element name="OndernemingAfnemerIdentificatie" type="OndernemingAfnemerIdentificatieType"/>
			</xsd:choice>
			<xsd:element name="FileEncoding" type="xsd:string"/>
			<xsd:element name="PrettyPrintedOutput" type="xsd:boolean"/>
			<xsd:element name="OutputMaxOccurs" type="xsd:int" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="PersoonAfnemerIdentificatieType">
		<xsd:sequence>
			<xsd:element name="Identificatie" type="xsd:string"/>
			<xsd:element name="Hoedanigheid" type="xsd:string" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="OndernemingAfnemerIdentificatieType">
		<xsd:sequence>
			<xsd:element name="Ondernemingsnummer" type="xsd:string"/>
			<xsd:element name="Vestigingsnummer" type="xsd:string" minOccurs="0"/>
		</xsd:sequence>
	</xsd:complexType>
	<!-- LDM -->
	<xsd:simpleType name="SectorType">
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[0-9]{1,3}"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="InstellingType">
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[0-9]{1,3}"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="OndernemingsNummerType">
		<xsd:restriction base="xsd:string">
			<xsd:pattern value="[0-1][0-9]{0,9}"/>
		</xsd:restriction>
	</xsd:simpleType>
	<!-- Generiek -->
	<xsd:complexType name="ConfiguratieType">
		<xsd:sequence>
			<xsd:element name="SleutelwaardeExpressies" type="SleutelwaardeExpressieType"/>
			<xsd:element name="SchemaFileName" type="xsd:string" minOccurs="0"/>
			<xsd:element name="Prefix" type="xsd:string"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="SleutelwaardeExpressieType">
		<xsd:sequence>
			<xsd:element name="SleutelwaardeExpressie" type="xsd:string" minOccurs="0" maxOccurs="unbounded"/>
		</xsd:sequence>
	</xsd:complexType>
	<xsd:complexType name="A1VoorleggingType">
