			<xsd:documentation>DIV</xsd:documentation>
		</xsd:annotation>
		<xsd:restriction base="xsd:string">
			<xsd:enumeration value="DIV"/>
		</xsd:restriction>
	</xsd:simpleType>
	<xsd:simpleType name="TransformatieTypeEnumType">
