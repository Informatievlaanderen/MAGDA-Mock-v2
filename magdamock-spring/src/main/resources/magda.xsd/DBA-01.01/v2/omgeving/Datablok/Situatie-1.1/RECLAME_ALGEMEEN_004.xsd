<xs:schema targetNamespace="urn:be:vlaanderen:omgeving:datablok:situatie:RECLAME_ALGEMEEN_004:001" elementFormDefault="unqualified" xmlns="urn:be:vlaanderen:omgeving:datablok:situatie:RECLAME_ALGEMEEN_004:001" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:dossier="urn:be:vlaanderen:omgeving:dossier:v2">
