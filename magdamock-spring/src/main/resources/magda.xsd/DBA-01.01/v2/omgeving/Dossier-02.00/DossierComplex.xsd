                                                        <xsd:documentation>De functie die de persoon uitoefent ten opzichte van de vertegenwoordigde persoon.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                        <xsd:element name="functie" type="dossier:VertegenwoordigingFunctie">
                                                <xsd:annotation>
                                                        <xsd:documentation>De functie die de persoon uitoefent ten opzichte van de vertegenwoordigde persoon.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                        <xsd:element name="vertegenwoordigde" type="dossier:Referentie">
                                                <xsd:annotation>
                                                        <xsd:documentation>De persoon die wordt vertegenwoordigd.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                </xsd:sequence>
                        </xsd:extension>
                </xsd:complexContent>
        </xsd:complexType>


        <xsd:complexType name="Voorwerp">
                <xsd:sequence>
                        <xsd:element name="externId" type="dossier:ExternId" minOccurs="0" maxOccurs="unbounded">
                                <xsd:annotation>
                                        <xsd:documentation>Een unieke sleutel van het Voorwerp die door een externe authentieke databron wordt toegekend.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="omschrijving" type="dossier:Titel" minOccurs="0">
                                <xsd:annotation>
                                        <xsd:documentation>Een tekstuele omschrijving van het voorwerp.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="plansymbool" type="dossier:Aanduiding" minOccurs="1" maxOccurs="1"/>
                        <xsd:element name="locatie" type="dossier:Referentie" minOccurs="1" maxOccurs="1">
                                <xsd:annotation>
                                        <xsd:documentation>Verwijst naar de locatie waar het voorwerp zich bevindt.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="situatie" type="dossier:Situatie" minOccurs="0" maxOccurs="2">
                                <xsd:annotation>
                                        <xsd:documentation>Er zijn 2 Voorwerp Situaties mogelijk: ASIS en TOBE</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                </xsd:sequence>
                <xsd:attribute name="id" type="xsd:ID"/>
                <xsd:attribute name="aard" type="dossier:CodeSimple">
                        <xsd:annotation>
                                <xsd:documentation>De aard van het voorwerp</xsd:documentation>
                        </xsd:annotation>
                </xsd:attribute>
        </xsd:complexType>
        <xsd:complexType name="VraagReferte">
                <xsd:sequence>
                        <xsd:element name="referte" type="dossier:ExternId"/>
                </xsd:sequence>
        </xsd:complexType>
     <!--   
             Dit complextype wordt nergens gebruikt
             <xsd:complexType name="GeheleWaarde">
                <xsd:annotation>
                        <xsd:documentation>Type voor waarden met een optionele eenheid.</xsd:documentation>
                </xsd:annotation>
                <xsd:simpleContent>
                        <xsd:extension base="xsd:integer">
                                <xsd:attribute name="eenheid" type="dossier:WaardeEenheid" use="required"/>
                        </xsd:extension>
                </xsd:simpleContent>
        </xsd:complexType>-->
        <xsd:complexType name="DecimaleWaarde">
                <xsd:annotation>
                        <xsd:documentation>Type voor waarden met een optionele eenheid.</xsd:documentation>
                </xsd:annotation>
                <xsd:simpleContent>
                        <xsd:extension base="xsd:decimal">
                                <xsd:attribute name="eenheid" type="dossier:WaardeEenheid" use="required"/>
                        </xsd:extension>
                </xsd:simpleContent>
        </xsd:complexType>
        <xsd:complexType name="ZoekDossierAbstract" xml:base="xsd:string">
                <xsd:sequence>
                        <xsd:element name="dossierIdentificatie" type="dossier:DossierIdentificatie">
                                <xsd:annotation>
                                        <xsd:documentation>De dossieridentificatie bevat de gegevens om een dossier te kunnen identificeren</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <!-- <xsd:element name="persoonAbstract" type="dossier:PersoonAbstract"/>-->
                        <xsd:element name="persoon" type="dossier:Persoon" minOccurs="1" maxOccurs="2"/>
                        <xsd:element name="locatie" type="dossier:Locatie">
                                <xsd:annotation>
                                        <xsd:documentation>Een locatie is de éénduidige bepaling van een ligging.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <!-- TODO MDP - DossierVerloop.Toestand.dossierfase vs DossierVerloop.Fase -->
                        <xsd:element name="dossierVerloop" type="dossier:DossierVerloop" minOccurs="0">
                                <xsd:annotation>
                                        <xsd:documentation>Het verloop van een dossier wordt beschreven aan de hand van verschillende fases. Deze fasen bevinden zich in het DossierVerloop. Er kan maar 1 actuele fase zijn die op het moment nog in behandeling is. Deze fase wordt geïdentificeerd aan de hand van de toestand.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <!-- TODO MDP - Kom hier overeen met  Beslissing van zoekDossier -->
                        <xsd:element name="gebeurtenis" type="dossier:Gebeurtenis" minOccurs="0">
                                <xsd:annotation>
                                        <xsd:documentation>Een Gebeurtenis omvat een registratie van een actie die een persoon uitvoert tijdens de levensloop van een dossier. Dit concept wordt gebruikt bij verschillende acties binnen het dossier.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                </xsd:sequence>
                <xsd:attribute name="creatietijdstip" type="xsd:dateTime">
                        <xsd:annotation>
                                <xsd:documentation>Het moment van create van het dossier. Dit tijdstip wordt automatisch ingevuld bij het aanmaken van het dossier.</xsd:documentation>
                        </xsd:annotation>
                </xsd:attribute>
                <xsd:attribute name="wijzigingstijdstip" type="xsd:dateTime">
                        <xsd:annotation>
                                <xsd:documentation>Het tijdstip waarop het dossier laatst werd gewijzigd. Dit tijdstip wordt automatisch aangepast bij elke wijziging van het dossier.</xsd:documentation>
                        </xsd:annotation>
                </xsd:attribute>
                <xsd:attribute name="versie" type="xsd:int">
                        <xsd:annotation>
                                <xsd:documentation>Een sequentieel nummer dat aangeeft hoeveel keer het dossier is aangepast Dit nummer wordt automatisch verhoogd bij elke wijziging van het dossier.</xsd:documentation>
                        </xsd:annotation>
                </xsd:attribute>
        </xsd:complexType>
        <xsd:complexType name="ZoekDossierResponse">
                <xsd:sequence>
                        <xsd:element name="zoekDossierAbstract" type="dossier:ZoekDossierAbstract" minOccurs="0" maxOccurs="unbounded"/>
                </xsd:sequence>
        </xsd:complexType>
        <xsd:complexType name="BewaarGebeurtenisResponse">
                <xsd:sequence>
                        <xsd:element name="dossierId" type="dossier:DossierId" minOccurs="0" maxOccurs="1">
                                <xsd:annotation>
                                        <xsd:documentation>Een unieke sleutel die het dossier identificeert binnen het platform. Bij het creëren van een dossier moet dit gelijk gesteld worden aan NIEUW.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="gebeurtenis" type="dossier:Gebeurtenis" minOccurs="0" maxOccurs="1"/>
                </xsd:sequence>
        </xsd:complexType>
        <xsd:complexType name="DossierIdentificatieMetGebeurtenis">
                <xsd:complexContent>
                        <xsd:extension base="dossier:BewaarGebeurtenisResponse"/>
                </xsd:complexContent>
        </xsd:complexType>
        <xsd:complexType name="ZoekGebeurtenisResponse">
                <xsd:sequence>
                        <xsd:element name="gebeurtenisInDossier" type="dossier:DossierIdentificatieMetGebeurtenis" minOccurs="0" maxOccurs="unbounded"/>
                </xsd:sequence>
        </xsd:complexType>


        <!--
           JSR-303 types

    -->
        <xsd:complexType name="StatusVlag">
                <xsd:sequence>
                        <xsd:element name="statusvlag" type="dossier:StatusVlagSimple"/>
                </xsd:sequence>
        </xsd:complexType>
        <xsd:complexType name="Code">
                <xsd:sequence>
                        <xsd:element name="code" type="dossier:CodeSimple"/>
                </xsd:sequence>
        </xsd:complexType>



        <!--
           JSR-303 types: gewijzigde extension base simplecontent voor JSR-303 validatie compliancy  
           
    -->

       


</xsd:schema>