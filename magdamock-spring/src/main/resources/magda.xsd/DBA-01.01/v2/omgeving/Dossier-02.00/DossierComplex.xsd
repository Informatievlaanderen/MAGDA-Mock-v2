        <xsd:complexType name="Persoon" abstract="true">
                <xsd:sequence>
                        <xsd:element name="persoonId" type="dossier:ExternId">
                                <xsd:annotation>
                                        <xsd:documentation>De identificatie waarmee deze persoon in externe systemen gekend is.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="hoedanigheid" type="dossier:Hoedanigheid" minOccurs="1" maxOccurs="unbounded">
                                <xsd:annotation>
                                        <xsd:documentation>Een persoon heeft minstens 1 hoedanigheid binnen een dossier.</xsd:documentation>
                                </xsd:annotation>

                        </xsd:element>

                </xsd:sequence>
                <xsd:attribute name="id" type="xsd:ID"/>
        </xsd:complexType>
        <xsd:complexType name="PrivaatPersoon">
                <xsd:complexContent>
                        <xsd:extension base="dossier:Persoon">
                                <xsd:sequence>
                                        <xsd:element name="naam" type="dossier:Naam">
                                                <xsd:annotation>
                                                        <xsd:documentation>De naam van deze persoon.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                        <xsd:element name="voornaam" type="dossier:Naam">
                                                <xsd:annotation>
                                                        <xsd:documentation>De voornaam van deze persoon.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                        <xsd:element name="geboorte" type="dossier:Geboorte" minOccurs="0">
                                                <xsd:annotation>
                                                        <xsd:documentation>Dit object bescrijft de geboortegegevens van een persoon.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                        <xsd:element name="handtekening" type="dossier:Handtekening" minOccurs="0" maxOccurs="unbounded">
                                                <xsd:annotation>
                                                        <xsd:documentation>Een handtekening bevat geen digitale handtekening in de strikte zin van het woord. Wanneer een persoon die ingelogd is met E-ID een vakje aankruist met een bepaalde verklaring ontstaat een moeilijk weerlegbaar vermoeden dat deze persoon de verklaring ondertekent.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                </xsd:sequence>
                        </xsd:extension>
                </xsd:complexContent>
        </xsd:complexType>
        <xsd:complexType name="Project" abstract="true">
                <xsd:sequence>
                        <xsd:element name="dossierFase" type="dossier:Referentie"/>
                        <xsd:group ref="dossier:ContourGroup"/>
                        <xsd:element name="dossierStuk" type="dossier:Referentie" minOccurs="0" maxOccurs="unbounded"/>
                </xsd:sequence>
                <xsd:attribute name="id" type="xsd:ID"/>
                <xsd:attribute name="moment" type="dossier:Moment"/>
        </xsd:complexType>
        <xsd:complexType name="RechtsPersoon">
                <xsd:complexContent>
                        <xsd:extension base="dossier:Persoon">
                                <xsd:sequence>
                                        <xsd:element name="maatschappelijkeNaam" type="dossier:Naam">
                                                <xsd:annotation>
                                                        <xsd:documentation>De naam van deze rechtspersoon.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                        <xsd:element name="commercieleNaam" type="dossier:Naam" minOccurs="0">
                                                <xsd:annotation>
                                                        <xsd:documentation>De commerciële naam van deze rechtspersoon.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                        <xsd:element name="afgekorteNaam" type="dossier:Naam" minOccurs="0">
                                                <xsd:annotation>
                                                        <xsd:documentation>De afkorting van de naam van deze rechtspersoon.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                        <xsd:element name="rechtsvorm" type="dossier:Rechtsvorm" minOccurs="0">
                                                <xsd:annotation>
                                                        <xsd:documentation>De rechtsvorm waar deze rechtspersoon aan voldoet.</xsd:documentation>
                                                </xsd:annotation>
                                        </xsd:element>
                                </xsd:sequence>
                        </xsd:extension>
                </xsd:complexContent>
        </xsd:complexType>
        <xsd:complexType name="Referentie">
                <xsd:annotation>
                        <xsd:documentation>Type voor referentie naar een interne id binnen dit document.</xsd:documentation>
                </xsd:annotation>
                <xsd:attribute name="idref" type="xsd:IDREF" use="required"/>
        </xsd:complexType>
        <xsd:complexType name="SituatieDatablok" abstract="true"/>
        <xsd:complexType name="Situatie">
                <xsd:sequence>
                        <xsd:element name="dossierFase" type="dossier:CodeMetReferentie">
                                <xsd:annotation>
                                        <xsd:documentation>De dossierfase waarin deze situatie toegevoegd werd.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <xsd:group ref="dossier:ContourGroup" minOccurs="0">
                                <xsd:annotation>
                                        <xsd:documentation>Geografische beschrijving van het voorwerp in deze situatie</xsd:documentation>
                                </xsd:annotation>
                        </xsd:group>
                        <xsd:element name="functie" type="dossier:Code" minOccurs="0" maxOccurs="unbounded">
                                <xsd:annotation>
                                        <xsd:documentation>De in de situatie toepasselijke functiecodes van het voorwerp</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="situatieDatablok" type="dossier:SituatieDatablok" minOccurs="0" maxOccurs="unbounded">
                                <xsd:annotation>
                                        <xsd:documentation>De details omtrent het voorwerp in de aangegeven situatie</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="dossierStukken" type="dossier:AbstractDossierStukLijst" minOccurs="0"/>
                </xsd:sequence>
                <xsd:attribute name="id" type="xsd:ID"/>
                <xsd:attribute name="moment" type="xsd:dateTime">
                        <xsd:annotation>
                                <xsd:documentation>Het tijdstip van deze situatie</xsd:documentation>
                        </xsd:annotation>
                </xsd:attribute>
                <xsd:attribute name="aard" type="dossier:CodeSimple" use="required">
                        <xsd:annotation>
                                <xsd:documentation>Eem kwalificatie van de situatie, bvb ASIS, AANGEVRAAGD, VERGUND, ASBUILT, ...</xsd:documentation>
                        </xsd:annotation>
                </xsd:attribute>
        </xsd:complexType>
        <xsd:complexType name="Straat">
                <xsd:sequence>
                        <xsd:element name="CodeSimple" type="dossier:ExternId" minOccurs="0"/>
                        <xsd:element name="naam" type="dossier:Straatnaam"/>
                </xsd:sequence>
        </xsd:complexType>
        <xsd:complexType name="Toestand">
                <xsd:sequence>
                        <xsd:element name="dossierFase" type="dossier:Referentie"/>
                        <xsd:element name="indieningsdatum" type="xsd:dateTime" minOccurs="0">
                                <xsd:annotation>
                                        <xsd:documentation>De datum waarop het dossier oorspronkelijk is ingediend.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                        <xsd:element name="uitersteDatum" type="xsd:dateTime" minOccurs="0">
                                <xsd:annotation>
                                        <xsd:documentation>De datum waarop het dossier volledig moet afgerond zijn.</xsd:documentation>
                                </xsd:annotation>
                        </xsd:element>
                </xsd:sequence>
        </xsd:complexType>
