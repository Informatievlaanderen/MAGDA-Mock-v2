	</xs:simpleType>
	</xs:element>
	<xs:element name="IsVerlicht">
	<xs:simpleType>
		<xs:restriction base="xs:string">
			<xs:enumeration value="J"/>
			<xs:enumeration value="N"/>
		</xs:restriction>
	</xs:simpleType>
	</xs:element>
	<xs:element name="BewegingType">
	<xs:simpleType>
		<xs:restriction base="xs:string">
