	<xs:simpleType>
		<xs:restriction base="xs:string"/>
	</xs:simpleType>
		</xs:attribute>
			</xs:extension>
		</xs:simpleContent>
	</xs:complexType>
	</xs:element>
	<xs:element name="ReclameOppervlakte" minOccurs="0">
	<xs:complexType>
		<xs:simpleContent>
