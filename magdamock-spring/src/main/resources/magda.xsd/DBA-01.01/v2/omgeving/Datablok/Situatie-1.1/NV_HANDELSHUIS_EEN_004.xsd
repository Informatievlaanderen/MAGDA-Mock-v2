                                                        <xs:restriction base="xs:string"/>
                                                    </xs:simpleType>
                                                </xs:attribute>
                                            </xs:extension>
                                        </xs:simpleContent>
                                    </xs:complexType>
                                </xs:element>
                                <xs:element name="PersoonAantal">
                                    <xs:simpleType>
                                        <xs:restriction base="xs:integer"/>
