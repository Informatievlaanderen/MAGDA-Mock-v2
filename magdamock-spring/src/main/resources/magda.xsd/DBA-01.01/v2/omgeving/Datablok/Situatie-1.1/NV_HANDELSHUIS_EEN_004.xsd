                                        <xs:simpleContent>
                                            <xs:extension base="xs:decimal">
                                                <xs:attribute name="eenheid" fixed="m">
                                                    <xs:simpleType>
                                                        <xs:restriction base="xs:string"/>
                                                    </xs:simpleType>
                                                </xs:attribute>
                                            </xs:extension>
                                        </xs:simpleContent>
                                    </xs:complexType>
                                </xs:element>
                            </xs:sequence>
                        </xs:complexType>
                    </xs:element>
                </xs:sequence>
            </xs:extension>
        </xs:complexContent>
    </xs:complexType>
