<xs:schema xmlns="http://participatie-02_00.vip.vlaanderen.be"
		   xmlns:generiek="http://generiek-02_00.vip.vlaanderen.be"
		   xmlns:sleutel="http://sleutel-02_00.vip.vlaanderen.be"
		   xmlns:onderwijs="http://onderwijs-02_00.vip.vlaanderen.be"
		   xmlns:vwo="http://vwo-02_00.vip.vlaanderen.be"
		   xmlns:xs="http://www.w3.org/2001/XMLSchema"
		   targetNamespace="http://participatie-02_00.vip.vlaanderen.be"
		   elementFormDefault="unqualified"
		   attributeFormDefault="unqualified"
		   version="2.00">
		   
	<xs:include schemaLocation="ParticipatieSimple.xsd"/>
	<xs:include schemaLocation="ParticipatieEnum.xsd"/>
	
	<xs:import namespace="http://generiek-02_00.vip.vlaanderen.be" schemaLocation="../Generiek-02.00/Generiek.xsd"/>
	<xs:import namespace="http://sleutel-02_00.vip.vlaanderen.be" schemaLocation="../Sleutel-02.00/Sleutel.xsd"/>
	<xs:import namespace="http://onderwijs-02_00.vip.vlaanderen.be" schemaLocation="../Onderwijs-02.00/Onderwijs.xsd"/>
	<xs:import namespace="http://vwo-02_00.vip.vlaanderen.be" schemaLocation="../Volwassenenonderwijs-02.00/Volwassenenonderwijs.xsd"/>
	<!--****************************************-->
	<!--* Segmenten - Niveau 1 (Hoofd)         *-->
	<!--****************************************-->
	<xs:complexType name="CriteriaZoekParticipatiesType">
		<xs:annotation>
			<xs:documentation>
                Bevat de input elementen/data die nodig zijn om de operatie uit te kunnen voeren.
            </xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="INSZ" type="sleutel:INSZType"/>
			<xs:element name="Periode" type="PeriodeType"/>
			<xs:element name="Volwassenenonderwijs" type="vwo:CriteriaZoekParticipatiesType" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--****************************************-->	
	<!--* Segmenten - Niveau 2 (Sub)           *-->
	<!--****************************************-->
	<xs:complexType name="ParticipatieType">
		<xs:sequence>
			<xs:element name="Oorsprong" type="generiek:TekstType"/>
			<xs:element name="Referte" type="generiek:Tekst2_0Type"/>
			<xs:element name="Lesdatum" type="generiek:VolledigDatumType"/>
			<xs:element name="Status" type="ParticipatieStatusType"/>
			<xs:element name="Volwassenenonderwijs" type="vwo:ParticipatieType" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--************************************************-->
	<!--* Segmenten - Niveau 3 (Samengesteld|Complex)  *-->
	<!--************************************************-->
	<xs:complexType name="ParticipatiesType">
		<xs:sequence>
			<xs:element name="Participatie" type="ParticipatieType" maxOccurs="unbounded"/>
		</xs:sequence>
	</xs:complexType>
	<xs:complexType name="PeriodeType">
		<xs:annotation>
			<xs:documentation>Periode waarbij begin en einddatum optioneel kunnen zijn</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Begin" type="generiek:VolledigDatumType">
				<xs:annotation>
					<xs:documentation>Begin datum</xs:documentation>
				</xs:annotation>
			</xs:element>
			<xs:element name="Einde" type="generiek:VolledigDatumType">
				<xs:annotation>
					<xs:documentation>Eind datum</xs:documentation>
				</xs:annotation>
			</xs:element>
		</xs:sequence>
	</xs:complexType>
	<!--***********************************************-->
	<!--* Segmenten - Niveau 4 (Enkelvoudig|Simple)   *-->
	<!--***********************************************-->
	<xs:complexType name="ParticipatieStatusType">
		<xs:annotation>
			<xs:documentation>Mate in hoeverre een cursist aan- dan wel afwezig was tijdens een les.</xs:documentation>
		</xs:annotation>
		<xs:complexContent>
			<xs:extension base="OpsommingsType"/>
		</xs:complexContent>
	</xs:complexType>
	<!--****************************************-->
	<!--* Segmenten - Niveau 5 (Simple Extend) *-->
	<!--****************************************-->
	<xs:complexType name="OpsommingsType">
		<xs:annotation>
			<xs:documentation>Abstract generalisatie type voor alle opsomming subtypes.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="Code" type="OpsommingsTypeCodeType"/>
			<xs:element name="Omschrijving" type="OpsommingsTypeOmschrijvingType" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
</xs:schema>
